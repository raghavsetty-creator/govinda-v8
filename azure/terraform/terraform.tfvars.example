# ─────────────────────────────────────────────────────────────────────────────
# GOVINDA Terraform Variables
# Copy to terraform.tfvars and fill in your values
# NEVER commit terraform.tfvars to git (it contains secrets)
# ─────────────────────────────────────────────────────────────────────────────

environment    = "prod"
location       = "centralindia"
vm_size        = "Standard_B2ms"
admin_username = "govindaadmin"
admin_password = "CHANGE_ME_Str0ng!Pass"   # Min 12 chars, upper+lower+number+symbol
allowed_ssh_ip = "YOUR_PUBLIC_IP/32"        # e.g. "203.0.113.5/32"

# AI API Keys (at least one required)
anthropic_api_key  = "sk-ant-..."
openai_api_key     = "sk-..."
gemini_api_key     = "AIza..."

# Broker (fill whichever you use)
dhan_client_id     = ""
dhan_access_token  = ""
fyers_app_id       = ""
fyers_access_token = ""

# Telegram alerts
telegram_bot_token = ""
telegram_chat_id   = ""

# Trading
trading_capital    = "500000"
