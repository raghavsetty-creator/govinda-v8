# ─────────────────────────────────────────────────────────────────
# GOVINDA v8 — Environment Variables
# Copy to .env and fill in values
# In production, Azure Key Vault injects these automatically
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────

# System
GOVINDA_ENV=production
LOG_LEVEL=INFO
TRADING_CAPITAL=500000

# ── AI Keys (at least one required) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── Broker (choose one) ──────────────────────────────────────────
# Fyers
FYERS_APP_ID=
FYERS_ACCESS_TOKEN=

# Dhan
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# Zerodha
ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# ── Azure (set by deploy script) ─────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_KEY_VAULT_URL=https://govinda-kv.vault.azure.net/

# ── Telegram Alerts ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_ON_SIGNAL=true
NOTIFY_ON_ERROR=true

# ── Paths (set by VM bootstrap) ──────────────────────────────────
DATA_DIR=/opt/govinda/data
MODEL_DIR=/opt/govinda/models
LOG_DIR=/opt/govinda/logs
MLFLOW_TRACKING_URI=/opt/govinda/mlruns
